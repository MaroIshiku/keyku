# Copy to .env if the stack uses dotenv files.
# Do not commit .env with real values.
TZ=Europe/Berlin
ISHIKU_APP_URL=https://keyku.example.local
ISHIKU_BASE_PATH=/
ISHIKU_DATA_DIR=/data
ISHIKU_LOG_LEVEL=info
ISHIKU_TRUST_PROXY=false
ISHIKU_SETUP_SECRET=replace-with-a-long-random-setup-secret
# Optional hardened alternative:
# ISHIKU_SETUP_SECRET_FILE=/run/secrets/ishiku_setup_secret
PORT=3000
PUBLIC_DIR=/app/public

# Fallback only; prefer Docker secrets:
# ISHIKU_SETUP_SECRET=replace-with-a-long-random-setup-secret
