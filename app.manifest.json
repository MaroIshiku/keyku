{
  "app_id": "keyku",
  "app_name": "Keyku - Key Vault",
  "app_subtitle": "Secure Steam key sharing",
  "app_symbol": "key",
  "primary_purpose": "Keyku manages Steam keys in a self-hosted vault.",
  "main_sections": ["vault"],
  "app_logo": {
    "src": "public/assets/logos/keyku.png",
    "favicon": "public/favicon.png",
    "pwa_icon_192": "public/icon-192.png",
    "pwa_icon_512": "public/icon-512.png",
    "pwa_maskable_512": "public/icon-512.png",
    "alt": "",
    "use_as_header_symbol": true,
    "use_as_favicon": true,
    "use_as_pwa_icon": true,
    "use_as_about_symbol": true,
    "use_as_profile_sheet_symbol": true,
    "use_as_empty_state_symbol": true
  },
  "first_run_setup": {
    "enabled": true,
    "route": "/setup",
    "require_setup_secret": true,
    "setup_secret_file_env": "ISHIKU_SETUP_SECRET_FILE",
    "setup_secret_env": "ISHIKU_SETUP_SECRET",
    "setup_secret_file_default": "/run/secrets/ishiku_setup_secret",
    "public_registration_after_first_admin": false,
    "admin_password_must_differ_from_setup_secret": true,
    "minimum_admin_password_length": 12
  },
  "readme_profile": {
    "repository_name": "keyku",
    "github_owner": "MaroIshiku",
    "public_repository": true,
    "short_description": "Self-hosted Steam key vault in the Pixel Soft Utility design system.",
    "docker_image": "ghcr.io/maroishiku/keyku:latest",
    "codex_notice_enabled": true
  },
  "default_theme": "lavender",
  "default_mode": "system",
  "has_account": true,
  "user_identity_fields": ["initials", "display_name", "username"],
  "contextual_status": ["vault_summary", "admin_info"],
  "primary_actions": ["create_key"],
  "technical_info": {
    "allowed_locations": ["About", "Admin Info", "Diagnostics", "Logs"]
  },
  "navigation_complexity": "single_view"
}
